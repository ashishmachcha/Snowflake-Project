# =============================================================================
# AWS Configuration for Snowflake Data Pipeline
# =============================================================================
# Copy this file to config.env and fill in your actual values.
# NEVER commit config.env to GitHub — it's in .gitignore.
#
# After filling in values, do a find-and-replace in the SQL files:
#   <YOUR_AWS_ACCOUNT_ID>   → your 12-digit AWS account ID
#   <YOUR_IMDB_BUCKET>      → your S3 bucket name for IMDB data
#   <YOUR_KAGGLE_BUCKET>    → your S3 bucket name for Kaggle data
#   <YOUR_MOVIELENS_BUCKET> → your S3 bucket name for MovieLens data
#   <YOUR_IMDB_ROLE>        → IAM role name for IMDB bucket access
#   <YOUR_KAGGLE_ROLE>      → IAM role name for Kaggle bucket access
#   <YOUR_MOVIELENS_ROLE>   → IAM role name for MovieLens bucket access
# =============================================================================

# AWS Account
AWS_ACCOUNT_ID=123456789012

# S3 Bucket Names
S3_BUCKET_IMDB=your-imdb-bucket-name
S3_BUCKET_KAGGLE=your-kaggle-bucket-name
S3_BUCKET_MOVIELENS=your-movielens-bucket-name

# IAM Role Names (used in storage integrations)
IAM_ROLE_IMDB=your-imdb-iam-role
IAM_ROLE_KAGGLE=your-kaggle-iam-role
IAM_ROLE_MOVIELENS=your-movielens-iam-role

# S3 Paths (relative paths within each bucket)
S3_PATH_IMDB=S3/
S3_PATH_KAGGLE=archive/
S3_PATH_MOVIELENS_32M=ml-32m/
S3_PATH_MOVIELENS_25M=ml-25m/
